# NorthWorld MCP Server — Environment Variables
# Copy to .env and fill in values

# ABR Web Services GUID (registered under NorthWorld)
ABR_GUID=15ec10c0-824d-4eaa-8692-fb1202933977

# Apollo API key (reuse from Lead Jen)
APOLLO_API_KEY=kIyube9j7yrx7ftjhMutlg

# Server port
PORT=3000

# API key auth — comma-separated valid keys for external callers
# e.g. MCP_API_KEYS=key1,key2,key3
MCP_API_KEYS=

# Freemium tier — calls before requiring a paid key
FREE_CALL_LIMIT=10

# SQLite database path
DB_PATH=./data/mcp.db

# Admin stats key (make something secure)
ADMIN_KEY=

# Stripe payment link for API key upgrade (update after Day 4)
STRIPE_PAYMENT_LINK=https://northworld.com.au/mcp-api
